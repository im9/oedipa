{
  "name": "@oedipa/m4l",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Oedipa M4L target — pnpm workspace root for engine and host packages.",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "bundle:host": "esbuild oedipa-host.entry.mjs --bundle --platform=node --format=esm --external:max-api --outfile=oedipa-host.mjs",
    "bake": "pnpm bundle:host && node scripts/maxpat-to-amxd.mjs"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0"
  }
}
