build/
build-asan/
.DS_Store
*.user
node_modules/

# m4l/engine build output — regenerate with `npm run build`
m4l/engine/dist/

# m4l/host build output — regenerate with `npm run build`
m4l/host/dist/

# m4l host entry bundle — regenerate with `pnpm bake` (esbuild output of oedipa-host.entry.mjs).
# `.mjs` (not `.js`): the freeze sandbox extracts this script to a tempdir
# without a sibling package.json, so `.js` would default to CJS and the
# bundle's `import Max from "max-api"` would fail to parse. Empirically
# verified 2026-05-01 via dev/dist Max console comparison.
m4l/oedipa-host.mjs

# Ableton Live project folder (auto-created when m4l/ is added as a Live Project)
m4l/Oedipa Project/

# Versioned un-frozen .amxd staged by `make release-m4l VERSION=X.Y.Z`.
# Ephemeral release helper — the user opens it in Max, Freezes, and
# Save-As's into dist/. m4l/Oedipa.amxd (the unversioned dev bake target)
# stays committed.
m4l/Oedipa-v*.amxd

# Release artifacts (frozen .amxd, future VST builds, etc.)
/dist/

# Apple Developer signing artefacts — must never be committed
# (per ADR 009 §Security).
*.p12
*.p8
*.cer
*.mobileprovision
*.keychain
